{
  "name": "scantpress",
  "version": "0.0.1",
  "author": "illusionaries",
  "type": "module",
  "dependencies": {
    "@giscus/vue": "catalog:framework",
    "@heroicons/vue": "catalog:framework",
    "jsdom": "catalog:markdown",
    "rolldown": "^1.1.4",
    "unconfig": "catalog:framework"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs"
    }
  },
  "bin": {
    "scant": "./dist/cli/index.mjs"
  },
  "files": [
    "./assets",
    "./components",
    "./dist",
    "./router",
    "./views",
    "./app.ts",
    "./App.vue",
    "./entry-*.ts",
    "./env.d.ts",
    "./glob-modules-provider.ts",
    "./index.html",
    "./injection.ts",
    "./modules.ts",
    "./utils.ts",
    "vite.config.ts"
  ],
  "peerDependencies": {
    "vue": "catalog:framework",
    "mathjax": "catalog:markdown",
    "tsdown": "^0.22.3",
    "typescript": "catalog:framework",
    "vite": "catalog:framework",
    "vite-plugin-vue-devtools": "catalog:framework",
    "@vitejs/plugin-vue": "catalog:framework",
    "@vueuse/core": "catalog:framework",
    "vue-tsc": "catalog:framework",
    "unocss": "catalog:framework",
    "@unocss/vite": "catalog:framework",
    "@mathjax/mathjax-mhchem-font-extension": "catalog:markdown"
  },
  "devDependencies": {
    "@scantpress/shared": "workspace:",
    "@scantpress/vite": "workspace:",
    "@types/html-minifier-terser": "catalog:build",
    "chalk": "catalog:build",
    "cheerio": "catalog:build",
    "commander": "^15.0.0",
    "fast-glob": "catalog:build",
    "feed": "catalog:build",
    "gray-matter": "catalog:build",
    "html-minifier-terser": "catalog:build",
    "husky": "catalog:linting",
    "image-size": "catalog:build",
    "js-yaml": "catalog:build",
    "pagefind": "catalog:build",
    "prettier": "catalog:linting",
    "sitemap": "catalog:build"
  },
  "scripts": {
    "//": "specifically use tsx to execute it in node environment",
    "build": "bunx tsx ./cli/index.ts build",
    "dev": "vite",
    "build-barrel": "tsdown"
  }
}
