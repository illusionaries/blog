{
  "$schema": "../../node_modules/turbo/schema.json",
  "extends": ["//"],
  "tasks": {
    "build-barrel": {
      "dependsOn": ["^build"]
    },
    "build": {
      "dependsOn": ["build-barrel"],
      "inputs": ["../../content/**/*", "./**/*"],
      "outputs": ["../../dist/**"]
    },
    "dev": {
      "dependsOn": ["build-barrel"],
      "cache": false,
      "persistent": true,
      "interactive": true
    }
  }
}
